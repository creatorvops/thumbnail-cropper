/* ------------------------------
   CONFIG
------------------------------ */
const CANVAS_CONFIG = {
  "1:1": { width: 512, height: 512, label: "Etsy Safe Area" },
  "4:3": { width: 800, height: 600, label: "Gumroad Perfect Box" }
};

const dropZone = document.getElementById("drop-zone");
const fileInput = document.getElementById("file-input");
const previewGrid = document.getElementById("preview-grid");
const previewCount = document.getElementById("preview-count");
const paddingSlider = document.getElementById("padding-slider");
const paddingValueLabel = document.getElementById("padding-value");
const bgColorInput = document.getElementById("bg-color");
const downloadZipBtn = document.getElementById("download-zip");
const statusText = document.getElementById("status-text");
const watermarkInput = document.getElementById("watermark-text");

const aspectSquare = document.getElementById("aspect-square");
const aspect4_3 = document.getElementById("aspect-4-3");

let processedImages = [];
let originalFiles = [];

/* ------------------------------
   HELPERS
------------------------------ */
function getAspect() {
  return aspect4_3.checked ? "4:3" : "1:1";
}
function getPadding() {
  return parseInt(paddingSlider.value, 10);
}
function getBgColor() {
  return bgColorInput.value;
}
function getWatermarkText() {
  return watermarkInput.value.trim();
}
function updatePaddingLabel() {
  paddingValueLabel.textContent = `(${getPadding()}px)`;
}
updatePaddingLabel();

/* ------------------------------
   DRAG & DROP
------------------------------ */
dropZone.addEventListener("click", () => fileInput.click());
dropZone.addEventListener("dragover", e => {
  e.preventDefault();
  dropZone.classList.add("border-sky-500", "bg-slate-800");
});
dropZone.addEventListener("dragleave", e => {
  e.preventDefault();
  dropZone.classList.remove("border-sky-500", "bg-slate-800");
});
dropZone.addEventListener("drop", e => {
  e.preventDefault();
  dropZone.classList.remove("border-sky-500", "bg-slate-800");
  const files = [...e.dataTransfer.files].filter(f => f.type.startsWith("image/"));
  if (files.length) handleFiles(files);
});
fileInput.addEventListener("change", e => {
  const files = [...e.target.files].filter(f => f.type.startsWith("image/"));
  if (files.length) handleFiles(files);
});

/* ------------------------------
   PROCESSING
------------------------------ */
function handleFiles(files) {
  originalFiles = originalFiles.concat(files);
  processedImages = [];
  previewGrid.innerHTML = "";
  statusText.textContent = "Processing...";
  downloadZipBtn.disabled = true;

  let remaining = files.length;

  files.forEach((file, index) => {
    const reader = new FileReader();
    reader.onload = evt => {
      const img = new Image();
      img.onload = () => {
        const { canvas, blob } = processImage(img);
        addPreview(canvas, file.name);
        processedImages.push({ filename: outputName(file.name, index), blob });

        remaining--;
        if (remaining === 0) finalize();
      };
      img.src = evt.target.result;
    };
    reader.readAsDataURL(file);
  });
}

function reprocessAll() {
  if (!originalFiles.length) return;

  processedImages = [];
  previewGrid.innerHTML = "";
  statusText.textContent = "Reprocessing...";
  downloadZipBtn.disabled = true;

  let remaining = originalFiles.length;

  originalFiles.forEach((file, index) => {
    const reader = new FileReader();
    reader.onload = evt => {
      const img = new Image();
      img.onload = () => {
        const { canvas, blob } = processImage(img);
        addPreview(canvas, file.name);
        processedImages.push({ filename: outputName(file.name, index), blob });

        remaining--;
        if (remaining === 0) finalize();
      };
      img.src = evt.target.result;
    };
    reader.readAsDataURL(file);
  });
}

/* ------------------------------
   CANVAS PROCESSING
------------------------------ */
function processImage(img) {
  const aspect = getAspect();
  const padding = getPadding();
  const bgColor = getBgColor();
  const watermark = getWatermarkText();

  const cfg = CANVAS_CONFIG[aspect];
  const canvas = document.createElement("canvas");
  canvas.width = cfg.width;
  canvas.height = cfg.height;

  const ctx = canvas.getContext("2d");

  // Background
  ctx.fillStyle = bgColor;
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  // Fit image inside padding
  const drawableW = canvas.width - padding * 2;
  const drawableH = canvas.height - padding * 2;
  const scale = Math.min(drawableW / img.width, drawableH / img.height);

  const w = img.width * scale;
  const h = img.height * scale;
  const x = (canvas.width - w) / 2;
  const y = (canvas.height - h) / 2;

  ctx.drawImage(img, x, y, w, h);

  // Safe-area outline
  drawSafeArea(ctx, cfg);

  // Watermark pattern
  if (watermark) drawWatermarkPattern(ctx, watermark, canvas.width, canvas.height);

  const blob = dataURLToBlob(canvas.toDataURL("image/png"));
  return { canvas, blob };
}

/* ------------------------------
   SAFE AREA OUTLINE
------------------------------ */
function drawSafeArea(ctx, cfg) {
  ctx.save();
  ctx.strokeStyle = "rgba(255,255,255,0.25)";
  ctx.lineWidth = 2;
  ctx.strokeRect(10, 10, cfg.width - 20, cfg.height - 20);

  ctx.fillStyle = "rgba(255,255,255,0.35)";
  ctx.font = "20px sans-serif";
  ctx.fillText(cfg.label, 20, 40);
  ctx.restore();
}

/* ------------------------------
   WATERMARK PATTERN (Diagonal)
------------------------------ */
function drawWatermarkPattern(ctx, text, width, height) {
  ctx.save();
  ctx.globalAlpha = 0.15;
  ctx.fillStyle = "#ccc";
  ctx.font = "32px sans-serif";

  ctx.translate(width / 2, height / 2);
  ctx.rotate(-Math.PI / 4);
  ctx.translate(-width / 2, -height / 2);

  const step = 200;
  for (let y = -height; y < height * 2; y += step) {
    for (let x = -width; x < width * 2; x += step) {
      ctx.fillText(text, x, y);
    }
  }

  ctx.restore();
}

/* ------------------------------
   PREVIEW
------------------------------ */
function addPreview(canvas, name) {
  const wrapper = document.createElement("div");
  wrapper.className = "flex flex-col items-center gap-2 bg-slate-900/60 rounded-lg p-2 border border-slate-700/60";

  const thumb = document.createElement("canvas");
  const size = 140;
  thumb.width = size;
  thumb.height = size;

  const tctx = thumb.getContext("2d");
  tctx.fillStyle = "#020617";
  tctx.fillRect(0, 0, size, size);

  const scale = Math.min(size / canvas.width, size / canvas.height);
  const w = canvas.width * scale;
  const h = canvas.height * scale;
  const x = (size - w) / 2;
  const y = (size - h) / 2;

  tctx.drawImage(canvas, x, y, w, h);

  const label = document.createElement("div");
  label.className = "text-[10px] text-slate-400 truncate w-full text-center";
  label.textContent = name;

  wrapper.appendChild(thumb);
  wrapper.appendChild(label);
  previewGrid.appendChild(wrapper);

  previewCount.textContent = `${previewGrid.children.length} image(s) processed`;
}

/* ------------------------------
   EXPORT
------------------------------ */
function outputName(originalName, index) {
  const base = originalName.replace(/\.[^/.]+$/, "");
  const aspect = getAspect().replace(":", "x");
  return `${base}_thumb_${aspect}_${index + 1}.png`;
}

function finalize() {
  if (processedImages.length) {
    statusText.textContent = `${processedImages.length} ready.`;
    downloadZipBtn.disabled = false;
  } else {
    statusText.textContent = "No images processed.";
    downloadZipBtn.disabled = true;
  }
}

downloadZipBtn.addEventListener("click", async () => {
  if (!processedImages.length) return;

  statusText.textContent = "Building ZIP...";
  downloadZipBtn.disabled = true;

  try {
    const zip = new JSZip();
    processedImages.forEach(item => zip.file(item.filename, item.blob));

    const content = await zip.generateAsync({ type: "blob" });
    saveAs(content, "thumbnails.zip");
    statusText.textContent = "ZIP downloaded.";
  } catch (err) {
    statusText.textContent = "Error creating ZIP.";
  }

  downloadZipBtn.disabled = false;
});

/* ------------------------------
   SETTINGS REPROCESS
------------------------------ */
[paddingSlider, bgColorInput, aspectSquare, aspect4_3, watermarkInput]
  .forEach(el => el.addEventListener("input", () => {
    updatePaddingLabel();
    if (processedImages.length) reprocessAll();
  }));

/* ------------------------------
   UTIL
------------------------------ */
function dataURLToBlob(dataURL) {
  const parts = dataURL.split(";base64,");
  const contentType = parts[0].split(":")[1];
  const raw = atob(parts[1]);
  const uInt8Array = new Uint8Array(raw.length);
  for (let i = 0; i < raw.length; i++) uInt8Array[i] = raw.charCodeAt(i);
  return new Blob([uInt8Array], { type: contentType });
}
