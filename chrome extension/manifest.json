{
  "manifest_version": 3,
  "name": "BatchCrop Pro (Thumbnail Cropper)",
  "description": "Right-click image cropper with safe-area guides and diagonal watermarking.",
  "version": "2.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "BatchCrop Pro"
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
